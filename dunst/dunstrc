[global]
    ### Отображение ###
    # Цвета (прозрачно-серый стиль)
    background = "#1e1e1ecc"    # Тёмно-серый с прозрачностью
    foreground = "#d3d3d3"      # Светло-серый текст
    frame_color = "#3a3a3a"     # Цвет рамки
    frame_width = 1
    separator_color = frame
    transparency = 15           # Прозрачность (0-100)
    corner_radius = 12          # Скругление углов

    ### Шрифт ###
    font = JetBrains Mono Nerd Font 10

    ### Поведение ###
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = no
    sticky_history = yes
    history_length = 20
    mouse_left_click = do_action
    mouse_middle_click = close_all
    mouse_right_click = close_current

    ### Геометрия (исправленный синтаксис) ###
    width = 300
    height = (0, 100)          # ← ИСПРАВЛЕНО: старый формат height = 100
    offset = (20, 30)          # ← ИСПРАВЛЕНО: старый формат offset = 20x30
    origin = top-right

    ### Формат ###
    format = "%s\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60

### Настройки срочности ###
[urgency_low]
    background = "#2a2a2acc"
    foreground = "#aaaaaa"
    frame_color = "#3a3a3a"
    timeout = 5

[urgency_normal]
    background = "#1e1e1ecc"
    foreground = "#d3d3d3"
    frame_color = "#4a4a4a"
    timeout = 8

[urgency_critical]
    background = "#3a1a1acc"
    foreground = "#ffffff"
    frame_color = "#882222"
    timeout = 0
